{
  "name": "clipeo",
  "private": true,
  "version": "0.1.11",
  "description": "Téléchargeur multimédia local et open source",
  "main": "dist-electron/electron/bootstrap.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json && node scripts/fix-electron.mjs",
    "verify:electron": "node scripts/verify-electron-build.mjs",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && npm run verify:electron && electron-builder --win nsis",
    "lint": "oxlint",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "fr.bob59.clipeo",
    "productName": "Clipéo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/yt-dlp.exe",
        "to": "bin/yt-dlp.exe"
      },
      {
        "from": "resources/deno.exe",
        "to": "bin/deno.exe"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/clipeo-icon.ico",
      "artifactName": "Clipeo-Installation.${ext}"
    },
    "nsis": {
      "installerIcon": "resources/clipeo-icon.ico",
      "uninstallerIcon": "resources/clipeo-icon.ico",
      "installerHeaderIcon": "resources/clipeo-icon.ico",
      "installerLanguages": [
        "fr_FR",
        "en_US",
        "es_ES",
        "de_DE"
      ],
      "multiLanguageInstaller": true,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "suceunq",
      "repo": "Clipeo"
    }
  }
}
